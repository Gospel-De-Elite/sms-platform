{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npx prisma generate"
    },
    "deploy": {
        "startCommand": "npx prisma migrate deploy && node src/app.js",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    }
}